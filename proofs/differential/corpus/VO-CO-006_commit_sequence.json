{
  "metadata": {
    "corpus_id": "VO-CO-006_commit_sequence",
    "invariant_id": "FV-CO-004",
    "description": "Canonical corpus for verifying CommitSequence strict monotonicity",
    "version": "1.0",
    "created": "2026-03-09"
  },
  "scenarios": [
    {
      "id": "mono_basic_3",
      "description": "3 validators, 4 rounds, 2 commits — sequence must be 0,1",
      "validators": 3,
      "rounds": [
        {
          "round": 0,
          "certificates": [
            {"origin": 0, "batch_digest_seed": "batch_r0_v0", "parents": []},
            {"origin": 1, "batch_digest_seed": "batch_r0_v1", "parents": []},
            {"origin": 2, "batch_digest_seed": "batch_r0_v2", "parents": []}
          ]
        },
        {
          "round": 1,
          "certificates": [
            {"origin": 0, "batch_digest_seed": "batch_r1_v0", "parents_from_round": 0},
            {"origin": 1, "batch_digest_seed": "batch_r1_v1", "parents_from_round": 0},
            {"origin": 2, "batch_digest_seed": "batch_r1_v2", "parents_from_round": 0}
          ]
        },
        {
          "round": 2,
          "certificates": [
            {"origin": 0, "batch_digest_seed": "batch_r2_v0", "parents_from_round": 1},
            {"origin": 1, "batch_digest_seed": "batch_r2_v1", "parents_from_round": 1},
            {"origin": 2, "batch_digest_seed": "batch_r2_v2", "parents_from_round": 1}
          ]
        },
        {
          "round": 3,
          "certificates": [
            {"origin": 0, "batch_digest_seed": "batch_r3_v0", "parents_from_round": 2},
            {"origin": 1, "batch_digest_seed": "batch_r3_v1", "parents_from_round": 2},
            {"origin": 2, "batch_digest_seed": "batch_r3_v2", "parents_from_round": 2}
          ]
        }
      ],
      "expected_commits": [
        {"sequence": 0, "anchor_round": 0},
        {"sequence": 1, "anchor_round": 2}
      ],
      "invariants": [
        "commit_sequence_strictly_monotonic",
        "commit_sequence_no_gaps"
      ]
    },
    {
      "id": "mono_no_leader_skip",
      "description": "Leader absent at anchor round — no commit, sequence unchanged",
      "validators": 4,
      "rounds": [
        {
          "round": 0,
          "certificates": [
            {"origin": 0, "batch_digest_seed": "batch_r0_v0", "parents": []},
            {"origin": 1, "batch_digest_seed": "batch_r0_v1", "parents": []},
            {"origin": 2, "batch_digest_seed": "batch_r0_v2", "parents": []},
            {"origin": 3, "batch_digest_seed": "batch_r0_v3", "parents": []}
          ]
        },
        {
          "round": 1,
          "certificates": [
            {"origin": 1, "batch_digest_seed": "batch_r1_v1", "parents_from_round": 0},
            {"origin": 2, "batch_digest_seed": "batch_r1_v2", "parents_from_round": 0},
            {"origin": 3, "batch_digest_seed": "batch_r1_v3", "parents_from_round": 0}
          ],
          "note": "Validator 0 (likely leader) missing — anchor round skip expected"
        }
      ],
      "expected_commits": [],
      "invariants": [
        "no_commit_when_leader_absent"
      ]
    },
    {
      "id": "mono_single_val",
      "description": "Single validator, trivial case — every anchor round commits",
      "validators": 1,
      "rounds": [
        {
          "round": 0,
          "certificates": [
            {"origin": 0, "batch_digest_seed": "batch_r0_v0", "parents": []}
          ]
        },
        {
          "round": 1,
          "certificates": [
            {"origin": 0, "batch_digest_seed": "batch_r1_v0", "parents_from_round": 0}
          ]
        }
      ],
      "expected_commits": [
        {"sequence": 0, "anchor_round": 0}
      ],
      "invariants": [
        "commit_sequence_strictly_monotonic"
      ]
    }
  ]
}
