# =============================================================================
# nexus-node Workspace — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Rust build artefacts
# ---------------------------------------------------------------------------
/target/

# Cargo.lock IS committed for this workspace (it contains binary executables).
# Do NOT add Cargo.lock here.

# ---------------------------------------------------------------------------
# Coverage output (cargo-tarpaulin / llvm-cov)
# ---------------------------------------------------------------------------
*.profraw
*.profdata
/coverage/
tarpaulin-report.html

# ---------------------------------------------------------------------------
# Benchmark output (Criterion)
# ---------------------------------------------------------------------------
/criterion/

# ---------------------------------------------------------------------------
# Editor and IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json

*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Environment / secrets (never commit private keys or .env files)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12

# ---------------------------------------------------------------------------
# macOS artefacts
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------------------
# Test / integration artefacts
# ---------------------------------------------------------------------------
/tests/tmp/
/tests/fixtures/generated/

# ---------------------------------------------------------------------------
# Move contract build artefacts (aptos move compile / nexus-wallet move build)
# ---------------------------------------------------------------------------
contracts/**/build/
**/nexus-artifact/
# Track pre-compiled bytecode in contracts/ — required by include_bytes! in tests
!contracts/**/nexus-artifact/
!contracts/**/nexus-artifact/**
tools/**/build/

# ---------------------------------------------------------------------------
# Tooling output
# ---------------------------------------------------------------------------
/nexus-node.log
/validator-*.log
*.flamegraph.svg
perf.data
perf.data.old
nohup.out
tools/nexus-bench/target/

# ---------------------------------------------------------------------------
# Local devnet (generated by scripts/setup-devnet.sh)
# ---------------------------------------------------------------------------
devnet/
devnet-*/
.tmp

fuzz/target/

# ---------------------------------------------------------------------------
# Local dev config
# ---------------------------------------------------------------------------
.config/*
!.config/nextest.toml

# ---------------------------------------------------------------------------
# GitHub Actions workflows (keep the workflow YAMLs, ignore the rest of .github/)
# ---------------------------------------------------------------------------
.github/*
!.github/workflows/